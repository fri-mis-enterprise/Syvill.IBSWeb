@using IBS.Models.Enums
@model CheckVoucherTradeViewModel

@{
    ViewData["Title"] = "Check Voucher Trade Supplier/Purchase Payment - Create";
}

<link rel="stylesheet" href="~/css/form-style.css">

<div class="loader-container">
    <div class="loader"></div>
    <div class="loader-text">Loading...</div>
</div>
<div class="card shadow border-0 mt-4">
    <div class="card-header bg-secondary bg-gradient ml-0 py-3">
        <div class="row">
            <div class="col-12 text-center">
                <h2 class="text-white py-2">@ViewData["Title"]</h2>
            </div>
        </div>
    </div>
    <div class="card-body p-4">
        <form method="post" enctype="multipart/form-data" id="paymentForm">
            @Html.AntiForgeryToken()
            <div class="row">
                <div class="col-12 col-md-4">
                    <div asp-validation-summary="ModelOnly" class="text-danger"></div>
                    <input type="hidden" asp-for="AdvancesCVNo"/>
                    <input type="hidden" asp-for="AppliedAdvanceAmount"/>
                    <div class="form-group mb-3">
                        <label class="control-label">Type<span class="required">*</span></label>
                        <select asp-for="Type" class="form-select js-select2 border-0 shadow" style="width:100%; max-height: 200px;" required>
                            <option value="" selected disabled>Select PO type</option>
                            @foreach (var documentType in Enum.GetValues<DocumentType>())
                            {
                                <option value="@documentType">@documentType.ToString()</option>
                            }
                        </select>
                        <span asp-validation-for="Type" class="text-danger"></span>
                    </div>
                    <div class="form-group mb-3">
                        <label asp-for="SupplierId" class="control-label"></label><span class="required">*</span>
                        <select asp-for="SupplierId" asp-items="@Model.Suppliers" class="form-select js-select2 GetPOList supplier" style="width:100%">
                            <option></option>
                        </select>
                        <span asp-validation-for="SupplierId" class="text-danger"></span>
                    </div>
                    <div class="form-floating mb-3">
                        <input asp-for="Payee" type="text" class="form-control supplierName" placeholder="" />
                        <label asp-for="Payee" class="control-label"></label>
                    </div>
                    <div class="form-floating mb-3">
                        <input asp-for="SupplierAddress" type="text" class="form-control" placeholder="" readonly />
                        <label asp-for="SupplierAddress" class="control-label"></label>
                    </div>
                    <div class="form-floating mb-3">
                        <input asp-for="SupplierTinNo" type="text" class="form-control" placeholder="" readonly />
                        <label asp-for="SupplierTinNo" class="control-label"></label>
                    </div>
                </div>
                <div class="col-12 col-md-8">
                    <div class="row mb-3 overflow-auto" style="max-height: 300px;">
                        <table>
                            <thead class="sticky-top bg-white">
                            <tr>
                                <th colspan="7" class="text-center py-3">
                                    <span>RR LIST</span>
                                    <span class="selected-rr-count ms-2 px-2 py-1 rounded-pill" style="display: none; background: linear-gradient(135deg, #5a9a9a, #4a8a8a); color: white; font-size: 0.75rem; vertical-align: middle;">
                                        <span id="selectedCount">0</span> selected
                                    </span>
                                </th>
                            </tr>
                            <tr>
                                <th><input type="checkbox" id="selectAll" onclick="toggleSelectAll(this)"></th>
                                <th>PO No's</th>
                                <th>RR No's</th>
                                <th>IS RR No's</th>
                                <th class="text-end">Amount</th>
                                <th class="text-end">Amount Paid</th>
                                <th class="text-end">Balance</th>
                            </tr>
                            </thead>
                            <tbody class="rrAmount">
                            </tbody>
                        </table>
                    </div>
                </div>
                    <div class="form-group mb-3">
                        <label asp-for="POSeries" class="control-label">Suppliers PO No.</label><span class="required">*</span>
                        <select asp-for="POSeries" asp-items="@Model.PONo" class="form-select js-multiple GetRRList" multiple="multiple" style="width:100%" required>
                            <option></option>
                        </select>
                        <span asp-validation-for="POSeries" class="text-danger"></span>
                    </div>
                    <div class="form-floating mb-3">
                        <input asp-for="OldCVNo" type="text" class="form-control" placeholder="" required/>
                        <span asp-validation-for="OldCVNo" class="text-danger"></span>
                        <label asp-for="OldCVNo" class="control-label mx-2">Old CV #<span class="required">*</span></label>
                    </div>
                    <div class="form-group mb-3">
                        <label asp-for="TransactionDate" class="control-label"></label><span class="required">*</span>
                        <input asp-for="TransactionDate"
                               type="Date"
                               class="form-control"
                               value="@DateTimeHelper.GetCurrentPhilippineTime().ToString("yyyy-MM-dd")"
                               min="@Model.MinDate.ToString("yyyy-MM-dd")"/>
                        <span asp-validation-for="TransactionDate" class="text-danger"></span>
                    </div>

                    <div class="form-group mb-3">
                        <label asp-for="BankId" class="control-label"></label><span class="required">*</span>
                        <select asp-for="BankId" asp-items="@Model.BankAccounts" class="form-select js-select2" id="bankAccounts" style="width:100%">
                            <option></option>
                        </select>
                        <span asp-validation-for="BankId" class="text-danger"></span>
                    </div>
                    <div class="form-floating mb-3">
                        <input asp-for="CheckNo" type="text" class="form-control" placeholder="" />
                        <label asp-for="CheckNo" class="control-label mx-2">Check No<span class="required">*</span></label>
                        <span asp-validation-for="CheckNo" class="text-danger"></span>
                    </div>
                    <div class="form-group mb-3">
                        <label asp-for="CheckDate" class="control-label"></label><span class="required">*</span>
                        <input asp-for="CheckDate" type="date" value="@DateTimeHelper.GetCurrentPhilippineTime().ToString("yyyy-MM-dd")" class="form-control" />
                        <span asp-validation-for="CheckDate" class="text-danger"></span>
                    </div>
                    <div class="form-floating mb-3">
                        <input asp-for="Particulars" type="text" class="form-control" placeholder="" />
                        <span asp-validation-for="Particulars" class="text-danger"></span>
                        <label asp-for="Particulars" class="control-label mx-2">Particulars<span class="required">*</span></label>
                    </div>
                    <div class="form-group mb-3">
                        <label class="control-label">Upload File (Optional)</label>
                        <input name="file" type="file" class="form-control" />
                    </div>
                <br />
                <div class="form-group table-responsive">
                    <button type="button" class="btn btn-info mb-3" data-bs-toggle="modal" data-bs-target="#AddAccEntry">
                        Add Entry
                    </button>
                    <table class="table" style="min-width: 800px">
                        <thead>
                            <tr>
                                <th>Account No.</th>
                                <th>Account Title</th>
                                <th>Debit</th>
                                <th>Credit</th>
                                <th></th>
                            </tr>
                        </thead>
                        <tbody id="accountingEntriesBody">
                            <tr>
                                <td><input type="text" name="AccountNumber" value="202010100" class="w-100" style='border:none' readonly /></td>
                                <td><input type='text' name="AccountTitle" value='AP-Trade Payable' class="w-100" style='border:none' readonly /></td>
                                <td><input type='text' name="Debit" value='0.0000' class="w-100 totalNetOfEWT" style='border:none' readonly /></td>
                                <td><input type='text' name="Credit" value='0.0000' class="w-100" style='border:none' readonly /></td>
                                <td></td>
                            </tr>
                            <tr>
                                <td><input type="text" name="AccountNumber" value="101010100" class="w-100" style='border:none' readonly /></td>
                                <td><input type='text' name="AccountTitle" value="Cash in Bank" class="w-100 accountTitle" style='border:none' readonly /></td>
                                <td><input type='text' name="Debit" value='0.0000' class="w-100" style='border:none' readonly /></td>
                                <td><input type='text' name="Credit" value="0.0000" class="w-100 cib-credit money editable-amount" style='border:none' oninput='updateTotalDebitAndCredit()' /></td>
                                <td></td>
                            </tr>
                            <tr id="advancesRow" style="display: none;">
                                <td><input type="text" name="AccountNumber" value="101060100" class="w-100" style='border:none' readonly /></td>
                                <td><input type='text' name="AccountTitle" value='Advances to Supplier' class="w-100" style='border:none' readonly /></td>
                                <td><input type='text' name="Debit" value='0.0000' class="w-100" id="advancesDebit" style='border:none' readonly /></td>
                                <td><input type='number' name="Credit" value='0.0000' class="w-100" id="advancesCredit" style='border:none' min="0" step="0.0001" /></td>
                                <td></td>
                            </tr>
                        </tbody>
                        <tbody>
                            <tr>
                                <td class="text-end" colspan="2">TOTAL:</td>
                                <td class="totalDebit">0.0000</td>
                                <td class="totalCredit">0.0000</td>
                                <td></td>
                            </tr>
                        </tbody>
                    </table>
                </div>
                <div id="advance-limit-message" class="text-muted small mb-2" style="display:none;"></div>
                <br />
                <div class="row pt-2">
                    <div class="col-6 col-md-3">
                        <button type="submit" class="btn btn-primary form-control">Create</button>
                    </div>
                    <div class="col-6 col-md-3">
                        <a asp-area="Filpride" asp-controller="CheckVoucherTrade" asp-action="Index" class="btn btn-outline-primary border form-control">Back to List</a>
                    </div>
                </div>
            </div>
        </form>
    </div>
</div>

<div class="modal fade" id="AddAccEntry" tabindex="-1" aria-labelledby="AddAccEntryLabel" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h1 class="modal-title fs-5" id="AddAccEntryLabel">Add Accounting Entry</h1>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <div class="form-group">
                    <label class="control-label">Account No.</label>
                    <select id="AccountNo" asp-items="@Model.COA" class="form-select js-select2" style="width: 100%">
                        <option></option>
                    </select>
                </div>
                <div class="form-group pt-4">
                    <label class="control-label">Debit</label>
                    <input id="debit" value="0.0000" class="form-control moneyInput" placeholder="0.0000" />
                </div>
                <div class="form-group pt-4">
                    <label class="control-label">Credit</label>
                    <input id="credit" value="0.0000" class="form-control moneyInput" placeholder="0.0000" />
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Close</button>
                <button type="button" class="btn btn-primary" onclick="saveAccountingEntry(event)">Create</button>
            </div>
        </div>
    </div>
</div>

@section Scripts
{
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
    <script>
        $(document).ready(function () {
            $('#AccountNo').select2({
                dropdownParent: $('#AddAccEntry'),
                placeholder: "Select an option...",
                allowClear: true,
                width: 'resolve',
                theme: 'classic'
            });

            updateTotalDebitAndCredit();
        });
    </script>
    <script>
        $(function () {
            $(".supplier").each(function () {
                var suppId = $(this).val();
                computeDefaultEntry(suppId)
            });
            $(".supplier").change(function () {
                var suppId = $(this).val();
                computeDefaultEntry(suppId)
            });

            function computeDefaultEntry(suppId) {
                if (suppId !== "") {
                    $.ajax({
                        url: "@Url.Action("GetSupplierDetails", "CheckVoucherTrade")",
                        method: "GET",
                        data: { supplierId: suppId },
                        success: function (data) {
                            if (data.address !== null || data.tinNo !== null) {
                                $("#SupplierAddress").val(data.address);
                                $("#SupplierTinNo").val(data.tinNo);
                                $(".supplierName").val(data.name);
                            } else {
                                $("#SupplierAddress").val("");
                                $("#SupplierTinNo").val("");
                                $(".supplierName").val("");
                            }
                        },
                        error: function (xhr, status, error) {
                            console.error('Error fetching TaxType:', error);
                        }
                    });
                } else {
                    $("#SupplierAddress").val("");
                    $("#SupplierTinNo").val("");
                    $(".supplierName").val("");
                }
            }
        });

        $(function () {
            $(".GetPOList").change(function () {
                var suppId = $(this).val();
                if (suppId !== "") {
                    $.ajax({
                        url: "@Url.Action("GetPOs", "CheckVoucherTrade")",
                        method: "GET",
                        data: { supplierId: suppId },
                        success: function (data) {
                            if (data) {
                                $("#POSeries").empty();
                                $.each(data, function (index, po) {
                                    if (po && po.poNumber) {
                                        $('#POSeries').append('<option value="' + po.poNumber + '">' + po.poNumber + '</option>');
                                    } else {
                                        console.error("Invalid PO object:", po);
                                    }
                                });
                            } else {
                                $("#POSeries").empty();
                            }
                        },
                        error: function (xhr, status, error) {
                            console.error('Error fetching POs:', error);
                        }
                    });
                } else {
                    $("#POSeries").empty();
                }
            });
        });
        
        $(".GetRRList").change(function () {
            var poNumber = $(this).val();
            displayRecords(poNumber);
            displayAdvances(poNumber);
        });

        // Function to update the selected count display
        function updateSelectedCount() {
            const count = selectedRecords.size;
            $('#selectedCount').text(count);
            
            if (count > 0) {
                $('.selected-rr-count').fadeIn();
            } else {
                $('.selected-rr-count').fadeOut();
            }
        }

        function displayRecords(poNumber) {
            $.ajax({
                url: "@Url.Action("GetRRs", "CheckVoucherTrade")",
                method: "GET",
                data: { poNumber: poNumber },
                traditional: true,
                success: function (data) {
                    const tbody = $('.rrAmount');
                    let totalGross = 0;
                    let totalAmountPaid = 0;
                    let totalBalance = 0;
                    let subTotalGross = 0;
                    let subTotalBalance = 0;
                    
                    tbody.empty();
                    // Reset selected count when loading new records
                    selectedRecords.clear();
                    updateSelectedCount();

                    if (data) {
                        let currentPO = null;

                        data.forEach((rr, index) => {
                            currentPO = rr.purchaseOrderNo;
                            const initialBalance = parseNumber(rr.balance);

                            const tr = $('<tr>').attr({ 'data-po': rr.purchaseOrderNo, 'data-balance': initialBalance });
                            const checkbox = $('<input>').attr({ type: 'checkbox', class: 'selectCheckbox' }).val(rr.id);
                            tr.append($('<td>').append(checkbox));
                            tr.append($('<td>').text(rr.purchaseOrderNo));
                            tr.append($('<td>').text(rr.receivingReportNo));
                            tr.append($('<td>').text(rr.oldRRNo));
                            tr.append($('<td>').addClass('text-end grossAmount').text(formatNumberToFour(rr.netOfEwtAmount)));
                            tr.append($('<td>').addClass('text-end').append($('<input>').attr({ type: 'text', class: 'paymentAmount text-end' }).hide()));
                            tr.append($('<td>').addClass('text-end balance').text(formatNumberToFour(initialBalance)));

                            tbody.append(tr);

                            subTotalGross   += parseNumber(rr.netOfEwtAmount);
                            subTotalBalance += initialBalance;
                            totalGross      += parseNumber(rr.netOfEwtAmount);
                            totalBalance    += initialBalance;

                            if (index === data.length - 1 || data[index + 1].purchaseOrderNo !== currentPO) {
                                const subTotal = $(`
                                <tr class="fw-bold bg-light subtotalRow" data-po="${currentPO}" data-balance="${subTotalBalance}">
                                    <td colspan="3"></td>
                                    <td class="fw-bold text-end">Subtotal (${rr.purchaseOrderNo}):</td>
                                    <td class="text-end subTotalGross">${formatNumberToFour(subTotalGross)}</td>
                                    <td class="text-end subTotalAmountPaid">0.00</td>
                                    <td class="text-end subTotalBalance">${formatNumberToFour(subTotalBalance)}</td>
                                </tr>
                            `);
                                tbody.append(subTotal);
                                subTotalGross   = 0;
                                subTotalBalance = 0;
                            }
                        });
                    }

                    const totalRow = $(`
                        <tr style="border-bottom:double;" class="sticky-lg-bottom">
                            <td colspan="7" class="pt-1"></td>
                        </tr>
                        <tr class="sticky-bottom bg-white">
                            <td colspan="3"></td>
                            <td class="fw-bold text-end p-2">Grand Total:</td>
                            <td class="text-end grandTotalGross" id="grandTotalRRAmount">${formatNumberToFour(totalGross)}</td>
                            <td class="text-end grandTotalAmountPaid" id="grandTotalNetAmount">0.00</td>
                            <td class="text-end grandTotalBalance" id="grandTotalNetOfEWT" data-balance="${totalBalance}">${formatNumberToFour(totalBalance)}</td>
                        </tr>
                    `);
                    tbody.append(totalRow);
                },
                error: function (xhr, status, error) {
                    console.error('Error fetching RRs:', error);
                }
            });
        }
        
        let availableAdvanceAmount = 0;

        function displayAdvances(poNumber){
            if (poNumber && poNumber.length > 0) {
                $.ajax({
                    url: "@Url.Action("CheckPOPaymentTerms", "CheckVoucherTrade")",
                    method: "GET",
                    data: { poNumbers: poNumber },
                    traditional: true,
                    success: function(response) {
                        if (response.hasCodOrPrepaid && response.advanceAmount > 0) {
                            availableAdvanceAmount = response.advanceAmount;
                            $("#advancesRow").show();
                            $("#advancesDebit").val(formatNumberToFour(0));
                            const initialAdvance = $("#AppliedAdvanceAmount").val();
                            $("#advancesCredit").val(initialAdvance);
                            $("#AdvancesCVNo").val(response.advanceCVNo);
                            $("#advance-limit-message").text(`Available advance: ${formatNumberToFour(availableAdvanceAmount)}`).show();
                            updateAmounts();
                        } else {
                            availableAdvanceAmount = 0;
                            $("#advancesRow").hide();
                            $("#advancesDebit").val("0.000");
                            $("#advancesCredit").val("0.000");
                            $("#AdvancesCVNo").val("");
                            $("#AppliedAdvanceAmount").val("0.0000");
                            $("#advance-limit-message").hide();
                            updateAmounts();
                        }
                    },
                    error: function(xhr, status, error) {
                        console.error('Error checking PO payment terms:', error);
                        availableAdvanceAmount = 0;
                        $("#advancesRow").hide();
                        $("#advancesDebit").val("0.000");
                        $("#advancesCredit").val("0.000");
                        $("#AdvancesCVNo").val("");
                        $("#AppliedAdvanceAmount").val("0.0000");
                        $("#advance-limit-message").hide();
                        updateAmounts();
                    }
                });
            } else {
                availableAdvanceAmount = 0;
                $("#advancesRow").hide();
                $("#advancesDebit").val("0.000");
                $("#advancesCredit").val("0.000");
                $("#AdvancesCVNo").val("");
                $("#AppliedAdvanceAmount").val("0.0000");
                $("#advance-limit-message").hide();
                updateAmounts();
            }
        }
        
        let selectedRecords = new Set();
        let allRecordsSelected = false;

        function toggleSelectAll(selectAllCheckbox) {
            const isChecked = selectAllCheckbox.checked;

            $(".selectCheckbox").each(function () {
                if (isChecked && !this.checked) {
                    $(this).prop("checked", true).trigger("change");
                } else if (!isChecked && this.checked) {
                    $(this).prop("checked", false).trigger("change");
                }
            });

            allRecordsSelected = isChecked;
        }

        $(document).on('change', '.selectCheckbox', function () {
            const row = $(this).closest('tr');
            const inputField = row.find('.paymentAmount');
            const initialBalance = parseNumber(row.attr('data-balance'));

            if (this.checked) {
                selectedRecords.add(this.value);
                inputField.val(formatNumberToFour(initialBalance)).addClass("inputAmount").show();
                row.find('.balance').text(formatNumberToFour(initialBalance - initialBalance));
            } else {
                selectedRecords.delete(this.value);
                inputField.removeAttr("name").hide().val('');
                row.find('.selectCheckbox').removeAttr("name");
                row.find('.balance').text(formatNumberToFour(initialBalance));
            }

            reindexSelected();
            updateAmounts();
            updateSelectedCount();

            // Update "Select All" checkbox state
            const totalCheckboxes = $('.selectCheckbox').length;
            const checkedCheckboxes = $('.selectCheckbox:checked').length;
            $('#selectAll').prop('checked', totalCheckboxes > 0 && totalCheckboxes === checkedCheckboxes);
        });

        function reindexSelected() {
            $(".selectCheckbox:checked").each(function (i) {
                const row = $(this).closest('tr');
                const inputField = row.find('.paymentAmount');

                $(this).attr("name", `RRs[${i}].Id`);
                inputField.attr("name", `RRs[${i}].Amount`);
            });
        }

        $(document).on('input', '.inputAmount', function () {
            const row = $(this).closest('tr');
            const initialBalance = parseNumber(row.attr('data-balance'));
            const paymentAmount = parseNumber($(this).val());

            if (paymentAmount > initialBalance) {
                $(this).addClass('is-invalid');
                $(this).val(formatNumberToFour(initialBalance));
                row.find('.balance').text(formatNumberToFour(0));
                updateAmounts();
                return;
            } else {
                $(this).removeClass('is-invalid');
                // negative values should not be allowed, reset to 0 if negative
                if (paymentAmount < 0) {
                    $(this).val(formatNumberToFour(0));
                    row.find('.balance').text(formatNumberToFour(initialBalance));
                    updateAmounts();
                    return;
                }
            }

            $(this).removeClass('is-invalid');

            row.find('.balance').text(formatNumberToFour(initialBalance - paymentAmount));
            updateAmounts();
        });

        function updateAmounts() {
            var totalNetOfEWT = 0;

            $(".subtotalRow").each(function () {
                const po = $(this).data("po");
                let amountInputs = document.querySelectorAll(`tr[data-po='${po}'] .inputAmount`);
                let subTotalAmountPaid = 0;

                amountInputs.forEach(function (input) {
                    subTotalAmountPaid += parseNumber(input.value);
                });

                totalNetOfEWT += subTotalAmountPaid;

                $(this).find(".subTotalAmountPaid").text(formatNumberToFour(subTotalAmountPaid));
                $(this).find(".subTotalBalance").text(formatNumberToFour(Math.abs($(this).data('balance') - subTotalAmountPaid)));
            });
            
            $(".totalNetOfEWT").val(formatNumberToFour(totalNetOfEWT));
            $(".grandTotalAmountPaid").text(formatNumberToFour(totalNetOfEWT));
            $(".grandTotalBalance").text(formatNumberToFour(Math.abs($(".grandTotalBalance").data('balance') - totalNetOfEWT)));

            var hasAdvances = $("#advancesRow").is(":visible");
            var advancesAmount = 0;
            if (hasAdvances) {
                var maxAdvanceAmount = Math.max(0, Math.min(availableAdvanceAmount, totalNetOfEWT));
                advancesAmount = parseNumber($("#advancesCredit").val());

                if (advancesAmount < 0 || isNaN(advancesAmount)) {
                    advancesAmount = 0;
                }

                if (advancesAmount > maxAdvanceAmount) {
                    advancesAmount = maxAdvanceAmount;
                    $("#advancesCredit").addClass("is-invalid");
                } else {
                    $("#advancesCredit").removeClass("is-invalid");
                }

                $("#advancesCredit").val(formatNumberToFour(advancesAmount));
            }
            $("#AppliedAdvanceAmount").val(formatNumberToFour(advancesAmount));

            var cashInBankAmount = totalNetOfEWT;
            if (hasAdvances) {
                cashInBankAmount = totalNetOfEWT - advancesAmount;
                if (cashInBankAmount < 0) cashInBankAmount = 0;
            }

            $(".cib-credit").val(formatNumberToFour(cashInBankAmount));
            
            updateTotalDebitAndCredit();
            validateDebitAndCredit();
        }

        $(document).on('input', '#advancesCredit', function () {
            updateAmounts();
        });

        $("#paymentForm").on("submit", function (event) {
            if (!validateDebitAndCredit()) {
                event.preventDefault();
            }
        });

        function saveAccountingEntry(event) {
            var accountNumber = $("#AccountNo").val();
            var accountTitle = $("#AccountNo option:selected").text().replace(/^\S+\s+/, "");
            var debit = parseNumber($("#debit").val());
            var credit = parseNumber($("#credit").val());

            if (!accountNumber || !accountTitle) {
                event.preventDefault();
                alert('Please select Account No.');
                return;
            }

            if (debit === 0 && credit === 0) {
                event.preventDefault();
                alert('Please input amount.');
                return;
            }

            if (debit !== 0 && credit !== 0) {
                event.preventDefault();
                alert('Invalid please input to debit or credit only.');
                return;
            }

            var newRow = `<tr class="manual-entry-row">
                <td><input type="text" name="AccountNumber" value="${accountNumber}" class="w-100" style='border:none' readonly /></td>
                <td><input type="text" name="AccountTitle" value="${accountTitle}" class="w-100" style='border:none' readonly /></td>
                <td><input type="text" name="Debit" value="${formatNumberToFour(debit)}" class="w-100 money editable-amount" style='border:none' oninput='updateTotalDebitAndCredit()' /></td>
                <td><input type="text" name="Credit" value="${formatNumberToFour(credit)}" class="w-100 money editable-amount" style='border:none' oninput='updateTotalDebitAndCredit()' /></td>
                <td><button type="button" class="btn btn-danger btn-sm" onclick="removeRow(this)">Remove</button></td>
            </tr>`;

            $("#accountingEntriesBody").append(newRow);
            $("#AddAccEntry").modal("hide");
            $("#AccountNo").val("").trigger("change");
            $("#debit").val("0.0000");
            $("#credit").val("0.0000");
            updateTotalDebitAndCredit();
        }

        function removeRow(button) {
            $(button).closest("tr").remove();
            updateTotalDebitAndCredit();
        }
        
        function updateTotalDebitAndCredit() {
            var totalDebit = 0;
            var totalCredit = 0;

            $("#accountingEntriesBody tr, .defaultEntry tr").each(function () {
                var debitInput = $(this).find("td:eq(2) input").val();
                var creditInput = $(this).find("td:eq(3) input").val();
                debitInput = debitInput ? String(debitInput) : "";
                creditInput = creditInput ? String(creditInput) : "";

                var debit = parseNumber(debitInput);
                var credit = parseNumber(creditInput);

                totalDebit += debit;
                totalCredit += credit;
            });

            $(".totalDebit").text(formatNumberToFour(totalDebit));
            $(".totalCredit").text(formatNumberToFour(totalCredit));
            $("#debit").val("0.0000");
            $("#credit").val("0.0000");
            validateDebitAndCredit();
        }

        function validateDebitAndCredit() {
            var totalDebit = parseNumber($(".totalDebit").text());
            var totalCredit = parseNumber($(".totalCredit").text());
            var errorMessage = "";
            var isValid = true;

            if ($("#balance-error-message").length === 0) {
                $("#accountingEntriesBody").after('<div id="balance-error-message" class="text-danger mt-2"></div>');
            }

            if (totalDebit !== totalCredit) {
                errorMessage = "Debit and Credit totals must be equal.";
                isValid = false;
            } else if (totalDebit === 0 && totalCredit === 0) {
                errorMessage = "Debit and Credit cannot both be zero.";
                isValid = false;
            } else if (totalDebit === 0 || totalCredit === 0) {
                errorMessage = "Debit and Credit cannot be zero.";
                isValid = false;
            }

            $("#balance-error-message").text(errorMessage);
            $("button[type='submit']").prop("disabled", !isValid);

            return isValid;
        }
        
        $('input[name="CheckNo"]').on('blur', function() {
            var checkNo = $(this).val();
            if (checkNo) {
                $.ajax({
                    url: '@Url.Action("CheckNoIsExist", "CheckVoucherTrade", new { area = "Filpride" })',
                    type: "GET",
                    data: { checkNo: checkNo },
                    success: function(exists) {
                        const submitButton = $('button[type="submit"]');

                        if (exists) {
                            alert("Check # already exists. Please enter a different number.");
                            $('input[name="CheckNo"]').addClass('is-invalid');

                            if ($('input[name="CheckNo"]').next('.text-danger.check-no-exists').length === 0) {
                                $('input[name="CheckNo"]').after('<span class="text-danger check-no-exists">Check # already exists</span>');
                            }

                            submitButton.prop('disabled', true);
                        } else {
                            $('input[name="CheckNo"]').removeClass('is-invalid');
                            $('.check-no-exists').remove();
                            submitButton.prop('disabled', false);
                        }
                    },
                    error: function(xhr, status, error) {
                        console.log("Error checking CheckNo: " + error);
                    }
                });
            }
        });
    </script>
}
