@using IBS.Models.Enums
@{
    ViewData["Title"] = "Provisional Receipt";
}

<link rel="stylesheet" href="~/css/index-style.css">

<div class="container-fluid mt-4">
    @Html.AntiForgeryToken()
    <div class="d-flex justify-content-between align-items-center bg-secondary p-3 rounded shadow">
        <h2 class="text-white m-0">@ViewData["Title"]</h2>
        <a asp-area="Filpride" asp-controller="ProvisionalReceipt" asp-action="Create" class="btn btn-light">
            <i class="bi bi-plus-circle"></i> New Receipt
        </a>
    </div>

    <div class="card shadow border-0 mt-3">
        <div class="card-body p-3">
            <div class="table-responsive" style="max-height: 70vh">
                <table class="table table-hover mb-0" id="paginatedTable">
                    <thead class="bg-light">
                    <tr>
                        <th>PR#</th>
                        <th>Date</th>
                        <th>Employee</th>
                        <th>Reference#</th>
                        <th>Total</th>
                        <th>Created By</th>
                        <th>Status</th>
                        <th class="text-center">Actions</th>
                    </tr>
                    </thead>
                </table>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        async function addDepositInfo(provisionalReceiptId) {
            const response = await fetch('@Url.Action("GetBanks", "ProvisionalReceipt", new { area = "Filpride" })');
            const banks = await response.json();
            let bankOptions = '<option value="">Select a bank</option>' + banks.map(b => `<option value="${b.value}">${b.text}</option>`).join('');
            let bankSelect = `<select id="swal-input2" class="swal2-select w-75" style="width: 75%;">${bankOptions}</select>`;
            let minDate = new Date('@(ViewBag.MinDate?.ToString("yyyy-MM-dd") ?? "1900-01-01")').toISOString().split('T')[0];
            let today = new Date().toISOString().split('T')[0];

            Swal.fire({
                title: 'Enter Deposit Info',
                html: `<input id="swal-input1" type="date" value="${today}" min="${minDate}" class="swal2-input w-75">` + bankSelect,
                icon: 'warning',
                showCancelButton: true,
                confirmButtonColor: '#3085d6',
                cancelButtonColor: '#d33',
                confirmButtonText: 'Next',
                didOpen: () => {
                    $('#swal-input2').select2({ dropdownParent: $('.swal2-container') });
                },
                preConfirm: () => {
                    const depositDate = document.getElementById('swal-input1').value;
                    const bankId = $('#swal-input2').val();
                    if (!depositDate || !bankId) {
                        Swal.showValidationMessage('Both Deposit Date and Bank are required');
                        return false;
                    }
                    return { depositDate, bankId };
                },
                willClose: () => {
                    if ($('#swal-input2').data('select2')) {
                        $('#swal-input2').select2('destroy');
                    }
                }
            }).then((result) => {
                if (result.isConfirmed) {
                    const { depositDate, bankId } = result.value;
                    window.location.href = `@Url.Action("Deposit", "ProvisionalReceipt", new { area = "Filpride" })/${provisionalReceiptId}?depositDate=${encodeURIComponent(depositDate)}&bankId=${encodeURIComponent(bankId)}`;
                }
            });
        }

        async function redeposit(provisionalReceiptId) {
            let minDate = new Date('@(ViewBag.MinDate?.ToString("yyyy-MM-dd") ?? "1900-01-01")').toISOString().split('T')[0];
            let today = new Date().toISOString().split('T')[0];

            Swal.fire({
                title: 'Enter Deposit Date',
                html: `<input id="swal-input1" type="date" value="${today}" min="${minDate}" class="swal2-input w-75">`,
                icon: 'warning',
                showCancelButton: true,
                confirmButtonColor: '#3085d6',
                cancelButtonColor: '#d33',
                confirmButtonText: 'Next',
                preConfirm: () => {
                    const depositDate = document.getElementById('swal-input1').value;
                    if (!depositDate) {
                        Swal.showValidationMessage('Deposit Date is required');
                        return false;
                    }
                    return depositDate;
                }
            }).then((result) => {
                if (result.isConfirmed) {
                    let depositDate = result.value;
                    window.location.href = `@Url.Action("Redeposit", "ProvisionalReceipt", new { area = "Filpride" })/${provisionalReceiptId}?redepositDate=${encodeURIComponent(depositDate)}`;
                }
            });
        }

        function returnCheck(id) {
            Swal.fire({
                title: 'Are you sure?',
                text: "You won't be able to revert this!",
                icon: 'warning',
                showCancelButton: true,
                confirmButtonColor: '#3085d6',
                cancelButtonColor: '#d33',
                confirmButtonText: 'Yes'
            }).then((result) => {
                if (result.isConfirmed) {
                    window.location.href = `@Url.Action("Return", "ProvisionalReceipt", new { area = "Filpride" })/${id}`;
                }
            });
        }

        async function applyClearingDate(provisionalReceiptId) {
            let minDate = new Date('@(ViewBag.MinDate?.ToString("yyyy-MM-dd") ?? "1900-01-01")').toISOString().split('T')[0];
            let today = new Date().toISOString().split('T')[0];

            Swal.fire({
                title: 'Enter Clearing Date',
                html: `<input id="swal-input1" type="date" value="${today}" min="${minDate}" class="swal2-input w-75">`,
                icon: 'warning',
                showCancelButton: true,
                confirmButtonColor: '#3085d6',
                cancelButtonColor: '#d33',
                confirmButtonText: 'Next',
                preConfirm: () => {
                    const clearingDate = document.getElementById('swal-input1').value;
                    if (!clearingDate) {
                        Swal.showValidationMessage('Clearing Date is required');
                        return false;
                    }
                    return clearingDate;
                }
            }).then((result) => {
                if (result.isConfirmed) {
                    let clearingDate = result.value;
                    window.location.href = `@Url.Action("ApplyClearingDate", "ProvisionalReceipt", new { area = "Filpride" })/${provisionalReceiptId}?clearingDate=${encodeURIComponent(clearingDate)}`;
                }
            });
        }

        function confirmVoid(id) {
            Swal.fire({
                title: 'Are you sure?',
                text: "You won't be able to revert this!",
                icon: 'warning',
                showCancelButton: true,
                confirmButtonColor: '#3085d6',
                cancelButtonColor: '#d33',
                confirmButtonText: 'Yes'
            }).then((result) => {
                if (result.isConfirmed) {
                    window.location.href = `@Url.Action("Void", "ProvisionalReceipt", new { area = "Filpride" })/${id}`;
                }
            });
        }

        function confirmCancel(id) {
            Swal.fire({
                title: "Please Input Remarks",
                html: "<input id='cancellationRemarks' type='text' class='swal2-input' placeholder='Remarks'>",
                focusConfirm: false,
                allowEscapeKey: false,
                allowOutsideClick: false,
                icon: 'warning',
                showCancelButton: true,
                confirmButtonColor: '#3085d6',
                cancelButtonColor: '#d33',
                confirmButtonText: 'Yes'
            }).then((result) => {
                if (result.isConfirmed) {
                    var encodedRemarks = encodeURIComponent($("#cancellationRemarks").val() || "");
                    window.location.href = `@Url.Action("Cancel", "ProvisionalReceipt", new { area = "Filpride" })?id=${id}&cancellationRemarks=${encodedRemarks}`;
                }
            });
        }

        $(document).ready(function () {
            $('#paginatedTable').DataTable({
                processing: true,
                serverSide: true,
                stateSave: true,
                ajax: {
                    url: "@Url.Action("GetProvisionalReceipts", "ProvisionalReceipt", new { area = "Filpride" })",
                    type: "POST",
                    data: function (d) {
                        d.__RequestVerificationToken = $('input[name="__RequestVerificationToken"]').val();
                        return d;
                    }
                },
                columns: [
                    { data: "seriesNumber" },
                    {
                        data: "transactionDate",
                        render: function (data) {
                            return new Date(data).toLocaleDateString('en-US', {
                                year: 'numeric',
                                month: 'short',
                                day: '2-digit'
                            });
                        }
                    },
                    { data: "employeeName" },
                    { data: "referenceNo" },
                    {
                        data: "total",
                        render: function (data) {
                            return $.fn.dataTable.render.number(',', '.', 2).display(data);
                        }
                    },
                    { data: "createdBy" },
                    {
                        data: "status",
                        render: function(data, type, row) {
                            var statusClass = row.status === "@nameof(CollectionReceiptStatus.Posted)"
                                || row.status === "@nameof(CollectionReceiptStatus.Deposited)"
                                || row.status === "@nameof(CollectionReceiptStatus.Redeposited)"
                                ? "bg-info"
                                : row.status === "@nameof(CollectionReceiptStatus.Cleared)"
                                    ? "bg-success"
                                    : row.status === "@nameof(CollectionReceiptStatus.Voided)"
                                    || row.status === "@nameof(CollectionReceiptStatus.Returned)"
                                        ? "bg-danger"
                                        : row.status === "@nameof(CollectionReceiptStatus.Canceled)"
                                            ? "bg-warning"
                                            : "";

                            return `<span class="badge rounded-pill ${statusClass}">${row.status}</span>`;
                        }
                    },
                    {
                        data: null,
                        orderable: false,
                        render: function (data, type, row) {
                            let dropdownHtml = `
                                <div class="dropdown" style="${row.voidedBy !== null || row.canceledBy !== null ? 'display:none;' : ''}">
                                    <button class="btn btn-light btn-sm dropdown-toggle w-100" type="button" data-bs-toggle="dropdown">
                                        <i class="bi bi-three-dots"></i>
                                    </button>
                                    <ul class="dropdown-menu dropdown-menu-end shadow-sm">`;

                            if (row.postedBy == null) {
                                dropdownHtml += `<li><a href="@Url.Action("Edit", "ProvisionalReceipt", new { area = "Filpride" })/${row.id}" class="dropdown-item">Edit</a></li>`;
                                dropdownHtml += `<li><a class="dropdown-item" onclick="confirmCancel(${row.id})">Cancel</a></li>`;
                                dropdownHtml += `<li><a href="@Url.Action("Print", "ProvisionalReceipt", new { area = "Filpride" })/${row.id}" class="dropdown-item">Preview</a></li>`;
                            } else {
                                const hasDeposit = row.depositedDate && row.depositedDate !== "";
                                const postedStatus = "@nameof(CollectionReceiptStatus.Posted)";
                                const clearedStatus = "@nameof(CollectionReceiptStatus.Cleared)";
                                const returnedStatus = "@nameof(CollectionReceiptStatus.Returned)";

                                if (!hasDeposit && row.status === postedStatus) {
                                    dropdownHtml += `<li><a class="dropdown-item" href="javascript:void(0);" onclick="addDepositInfo(${row.id})">Add Deposit Info</a></li>`;
                                } else if (!hasDeposit && row.status === returnedStatus) {
                                    dropdownHtml += `<li><a class="dropdown-item" href="javascript:void(0);" onclick="redeposit(${row.id})">Redeposit</a></li>`;
                                } else if (hasDeposit && row.status !== returnedStatus && row.status !== clearedStatus) {
                                    dropdownHtml += `<li><a class="dropdown-item" href="javascript:void(0);" onclick="applyClearingDate(${row.id})">Apply Clearing Date</a></li>`;
                                } else {
                                    dropdownHtml += `<li><a class="dropdown-item" href="javascript:void(0);" onclick="returnCheck(${row.id})">Return Check</a></li>`;
                                }

                                dropdownHtml += `<li><a href="@Url.Action("Print", "ProvisionalReceipt", new { area = "Filpride" })/${row.id}" class="dropdown-item">Preview</a></li>`;
                                dropdownHtml += `<li><a class="dropdown-item" onclick="confirmVoid(${row.id})">Void</a></li>`;
                            }

                            dropdownHtml += `</ul></div>`;
                            return dropdownHtml;
                        }
                    }
                ]
            });
        });
    </script>
}
