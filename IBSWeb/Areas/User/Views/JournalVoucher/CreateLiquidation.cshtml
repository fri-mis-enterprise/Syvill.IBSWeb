@using IBS.Models.Enums
@model JournalVoucherViewModel

@{
    ViewData["Title"] = "Journal Voucher - Create Liquidation";
}

<link rel="stylesheet" href="~/css/form-style.css">

<div class="loader-container">
    <div class="loader"></div>
    <div class="loader-text">Loading...</div>
</div>
<div class="card shadow border-0 mt-4">
    <div class="card-header bg-secondary bg-gradient ml-0 py-3">
        <div class="row">
            <div class="col-12 text-center">
                <h2 class="text-white py-2">@ViewData["Title"]</h2>
            </div>
        </div>
    </div>
    <div class="card-body p-4">
        <form method="post" enctype="multipart/form-data">
            @Html.AntiForgeryToken()
            <div class="row">
                <div class="col-12 col-md-4">
                    <div asp-validation-summary="ModelOnly" class="text-danger"></div>

                    <div class="form-group mb-3">
                        <label class="control-label">Type<span class="required">*</span></label>
                        <select asp-for="Type" class="form-select js-select2 border-0 shadow"
                                style="width:100%; max-height: 200px;" required>
                            <option value="" selected disabled>Select document type</option>
                            @foreach (DocumentType journalVoucherType in Enum.GetValues<DocumentType>())
                            {
                                <option value="@journalVoucherType"
                                        selected="@(journalVoucherType == DocumentType.Undocumented)">@journalVoucherType.ToString()</option>
                            }
                        </select>
                        <span asp-validation-for="Type" class="text-danger"></span>
                    </div>
                    <div class="form-group mb-3">
                        <label asp-for="TransactionDate" class="control-label">Transaction Date</label><span
                            class="required">*</span>
                        <input asp-for="TransactionDate"
                               type="Date"
                               class="form-control"
                               value="@DateTimeHelper.GetCurrentPhilippineTime().ToString("yyyy-MM-dd")"
                               min="@Model.MinDate.ToString("yyyy-MM-dd")"/>
                        <span asp-validation-for="TransactionDate" class="text-danger"></span>
                    </div>
                    <div class="form-floating mb-3">
                        <input asp-for="References" type="text" class="form-control" placeholder=""/>
                        <span asp-validation-for="References" class="text-danger"></span>
                        <label asp-for="References" class="control-label"></label>
                    </div>
                    <div class="form-group mb-3">
                        <label asp-for="EmployeeId" class="control-label"></label><span class="required">*</span>
                        <select asp-for="EmployeeId" asp-items="@Model.Employees"
                                class="form-select js-select2 border-0 shadow" style="width:100%; max-height: 200px;"
                                required>
                            <option></option>
                        </select>
                        <span asp-validation-for="EmployeeId" class="text-danger"></span>
                    </div>
                    <div class="form-group mb-3">
                        <label class="control-label">CV No.</label><span class="required">*</span>
                        <select asp-for="CVId" asp-items="@Model.CheckVoucherHeaders"
                                class="form-select js-select2 checkVoucher border-0 shadow"
                                style="width:100%; max-height: 200px;" required>
                            <option></option>
                        </select>
                        <span asp-validation-for="CVId" class="text-danger"></span>
                    </div>
                    <div class="form-group mb-3">
                        <label asp-for="PRNo" class="control-label"></label>
                        <select asp-for="PRNo" asp-items="@Model.ProvisionalReceipts"
                                class="form-select js-select2 border-0 shadow" style="width:100%; max-height: 200px;">
                            <option></option>
                        </select>
                        <span asp-validation-for="PRNo" class="text-danger"></span>
                    </div>
                    <div class="form-floating mb-3">
                        <input asp-for="Particulars" type="text" class="form-control" placeholder=""/>
                        <label asp-for="Particulars" class="control-label">Particulars<span
                                class="required">*</span></label>
                        <span asp-validation-for="Particulars" class="text-danger"></span>
                    </div>
                    <div class="form-floating mb-3">
                        <textarea asp-for="JVReason" type="text" class="form-control" placeholder="Enter JV Reason"
                                  style="height: 100px"></textarea>
                        <label asp-for="JVReason" class="control-label">Reason<span class="required">*</span></label>
                        <span asp-validation-for="JVReason" class="text-danger"></span>
                    </div>
                </div>
                <div class="col-12 col-md-8 tradeList">
                    <div class="row pb-3 overflow-auto">

                        <div class="table-responsive">
                            <table class="w-100">
                                <thead>
                                <tr style="border: 1px solid black;">
                                    <th colspan="2" style="padding-left:20px;">I. PAYEE DETAILS</th>
                                    <th colspan="1" class="text-end"><b>Date : </b></th>
                                    <td id="date"></td>
                                </tr>
                                </thead>
                                <tbody>
                                <tr>
                                    <td style="width:11%; padding-left:20px;">Name :</td>
                                    <td id="name"></td>
                                    <td style="width:50%;" colspan="2" class="text-nowrap">Other References:</td>
                                </tr>
                                <tr>
                                    <td style="padding-left:20px;">Address :</td>
                                    <td id="address"></td>
                                    <td style="width:6%;">PO # :</td>
                                    <td id="poNo"></td>
                                </tr>
                                <tr>
                                    <td style="padding-left:20px;">TIN # :</td>
                                    <td id="tinNo"></td>
                                    <td>SI # :</td>
                                    <td id="siNo"></td>
                                </tr>
                                <tr>
                                    <td style="padding-left:20px;" class="text-nowrap"></td>
                                    <td></td>
                                    <td></td>
                                    <td></td>
                                </tr>
                                </tbody>
                            </table>
                        </div>
                        <div class="table-responsive" style="margin-top:20px;">
                            <table class="w-100">
                                <thead>
                                <tr style="border: 1px solid black;">
                                    <th colspan="4" style="padding-left:20px;">II. CHECK DETAILS</th>
                                </tr>
                                </thead>
                                <tbody>
                                <tr>
                                    <td style="width:15%; padding-left:20px;">Payee :</td>
                                    <td style="width:65%;" id="payee"></td>
                                    <td class="text-end" id="amount"></td>
                                </tr>
                                <tr>
                                    <td style="padding-left:20px;"></td>
                                    <td class="w-25"></td>
                                    <td></td>
                                </tr>
                                <tr>
                                    <td style="padding-left:20px;">Particulars :</td>
                                    <td id="particulars"></td>
                                    <td></td>
                                </tr>
                                <tr>
                                    <td style="padding-left:20px;">Check #:</td>
                                    <td id="checkNo"></td>
                                    <td></td>
                                </tr>
                                </tbody>
                            </table>
                        </div>

                        <div class="table-responsive" style="margin-top:20px;">
                            <table class="w-100">
                                <thead>
                                <tr style="border: 1px solid black;">
                                    <th colspan="4" style="padding-left:20px;">III. ACCOUNTING ENTRIES</th>
                                </tr>
                                </thead>
                                <tbody>
                                <tr>
                                    <td style="padding-left:20px;"></td>
                                    <th class="text-end">DEBIT</th>
                                    <th class="text-end">CREDIT</th>
                                </tr>
                                </tbody>
                                <tbody id="tableBody"></tbody>
                                <tbody>
                                <tr style="border-bottom:double;"></tr>
                                <tr>
                                    <td class="text-end">TOTAL</td>
                                    <td class="text-end" id="totalDebit"></td>
                                    <td class="text-end" id="totalCredit"></td>
                                </tr>
                                </tbody>
                            </table>
                        </div>

                    </div>
                </div>

                <br/>
                <div class="form-group table-responsive">
                    <button type="button" class="btn btn-info" data-bs-toggle="modal" data-bs-target="#AddAccEntry">
                        Add Entry
                    </button>
                    <table class="table" style="min-width: 800px">
                        <thead>
                        <tr>
                            <th>Account No.</th>
                            <th>Account Title</th>
                            <th>Debit</th>
                            <th>Credit</th>
                            <th>Sub Acct</th>
                            <th></th>
                        </tr>
                        </thead>
                        <tbody id="accountingEntriesBody">
                        @if (Model.Details != null)
                        {
                            @for (var i = 0; i < Model.Details.Count; i++)
                            {
                                <tr data-index="@i">
                                    <td>
                                        <input type="text" name="Details[@i].AccountNumber"
                                               value="@Model.Details[i].AccountNumber" style="border:none" class="w-100"
                                               readonly/>
                                    </td>
                                    <td>
                                        <input type="text" name="Details[@i].AccountTitle"
                                               value="@Model.Details[i].AccountTitle" style="border:none" class="w-100"
                                               readonly/>
                                    </td>
                                    <td>
                                        <input name="Details[@i].Debit" value="@Model.Details[i].Debit.ToString("N4")"
                                               style="border:none" class="w-100 money editable-amount"
                                               oninput="updateTotalDebitAndCredit()"/>
                                    </td>
                                    <td>
                                        <input name="Details[@i].Credit" value="@Model.Details[i].Credit.ToString("N4")"
                                               style="border:none" class="w-100 money editable-amount"
                                               oninput="updateTotalDebitAndCredit()"/>
                                    </td>
                                    <td>
                                        <input value="@Model.Details[i].SubAccountCodeName" style="border:none"
                                               class="w-100" readonly/>
                                        <input name="Details[@i].SubAccountId" type="hidden"
                                               value="@Model.Details[i].SubAccountId"/>
                                        <input name="Details[@i].SubAccountCodeName" type="hidden"
                                               value="@Model.Details[i].SubAccountCodeName"/>
                                    </td>
                                    <td>
                                        <button type="button" class="btn btn-danger btn-sm" onclick="removeRow(this)">
                                            Remove
                                        </button>
                                    </td>
                                </tr>
                            }
                        }
                        </tbody>
                        <tfoot>
                        <tr>
                            <td class="text-end" colspan="3">TOTAL:</td>
                            <td class="totalDebit">0.0000</td>
                            <td class="totalCredit">0.0000</td>
                            <td></td>
                            <td></td>
                        </tr>
                        </tfoot>
                    </table>
                </div>
                <br/>
                <div class="row pt-2">
                    <div class="col-6 col-md-3">
                        <button type="submit" class="btn btn-primary form-control"
                                onclick="return validateDebitAndCredit(event)">Create
                        </button>
                    </div>
                    <div class="col-6 col-md-3">
                        <a asp-area="User" asp-controller="JournalVoucher" asp-action="Index"
                           class="btn btn-outline-primary border form-control">Back to List</a>
                    </div>
                </div>
            </div>
        </form>
    </div>
</div>

<!-- Modal -->
<div class="modal fade" id="AddAccEntry" tabindex="-1" aria-labelledby="AddAccEntryLabel" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h1 class="modal-title fs-5" id="AddAccEntryLabel">Add Accounting Entry</h1>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <div asp-validation-summary="ModelOnly" class="text-danger"></div>
                <div class="form-group">
                    <label class="control-label">Account No.</label>
                    <select asp-items="@Model.COA" class="form-select js-select2" style="width: 100%" id="AccountNo">
                        <option></option>
                    </select>
                    <span class="text-danger"></span>
                </div>
                <div class="form-group pt-4">
                    <label class="control-label">Debit</label>
                    <input id="debit" value="0.0000" class="form-control moneyInput" placeholder="0.0000"/>
                    <span class="text-danger"></span>
                </div>
                <div class="form-group pt-4">
                    <label class="control-label">Credit</label>
                    <input id="credit" value="0.0000" class="form-control moneyInput" placeholder="0.0000"/>
                    <span class="text-danger"></span>
                </div>
                <div class="row">
                    <div class="col-12" id="categoryContainer"></div>
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" id="modalClose" data-bs-dismiss="modal">Close</button>
                <button type="button" class="btn btn-primary" onclick="saveAccountingEntry(event)">Create</button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
    <script>
        $(document).ready(function () {
            $('#AccountNo').select2({
                dropdownParent: $('#AddAccEntry'),
                placeholder: "Select an option...",
                allowClear: true,
                width: 'resolve',
                theme: 'classic'
            });

            $('#EmployeeId, #CVId, #PRNo').select2({
                placeholder: "Select an option...",
                allowClear: true,
                width: 'resolve',
                theme: 'classic'
            });

            // Initialize totals on page load
            updateTotalDebitAndCredit();
        });

        $("#AccountNo").on("change", seeIfNeedSupplier);

        function seeIfNeedSupplier() {
            let accountNumber = $("#AccountNo").val();
            let selectionGroup = $("#selectionGroup");

            const triggerAccounts = [
                "101020500",  // AR Non Trade Receivable
            ];

            if (triggerAccounts.includes(accountNumber)) {
                if (selectionGroup.length === 0) {
                    showSupplierSelectList();
                }
            } else {
                if (selectionGroup.length !== 0) {
                    selectionGroup.remove();
                }
            }
        }

        function showSupplierSelectList() {
            $.ajax({
                url: '@Url.Action("GetNonTradeSupplierSelectList", "JournalVoucher", new { area = "User" })',
                type: "GET",
                success: function (data) {
                    if (Array.isArray(data) && data.length > 0) {
                        let newRow = `
                        <div class="form-group pt-4" id="selectionGroup">
                            <label class="control-label">Select Supplier</label>
                            <select id="SubAccountId" class="form-select js-select2 w-100"></select>
                            <span class="text-danger" id="supplierError"></span>
                        </div>`;

                        $("#categoryContainer").append(newRow);

                        $('#SubAccountId').select2({
                            dropdownParent: $('#AddAccEntry'),
                            placeholder: "Select an option...",
                            allowClear: true,
                            width: 'resolve',
                            theme: 'classic'
                        });

                        $("#SubAccountId").append('<option value="">');

                        $.each(data, function (index, item) {
                            $("#SubAccountId").append($('<option>', {
                                value: item.value,
                                text: item.text
                            }));
                        });
                    }
                },
                error: function (xhr, status, error) {
                    console.error('Error fetching supplier list:', error);
                }
            });
        }
    </script>

    <script>
        function saveAccountingEntry(event) {
            var accountNumber = $("#AccountNo").val();
            var accountNumberText = $("#AccountNo option:selected").text();
            var debit = parseNumber($("#debit").val());
            var credit = parseNumber($("#credit").val());
            var subAccountId = safeVal("#SubAccountId");
            var subAccountCodeName = safeText("#SubAccountId option:selected");

            if (accountNumberText === "") {
                event.preventDefault();
                alert('Please select Account No.');
                return;
            }

            // Validate supplier if dropdown is visible
            if ($("#selectionGroup").length !== 0) {
                if (!subAccountId) {
                    event.preventDefault();
                    $("#supplierError").text("Please select a sub-account.");
                    return;
                } else {
                    $("#supplierError").text("");
                }
            }

            if (debit === 0 && credit === 0) {
                event.preventDefault();
                alert('Please input amount.');
                return;
            }

            if (debit !== 0 && credit !== 0) {
                event.preventDefault();
                alert('Invalid please input to debit or credit only.');
                return;
            }

            var formattedDebit = formatNumber(debit);
            var formattedCredit = formatNumber(credit);

            // Get the current index for proper model binding
            var currentIndex = $("#accountingEntriesBody tr").length;

            var newRow = `<tr data-index="${currentIndex}">
                            <td>
                                <input type='text' name='Details[${currentIndex}].AccountNumber' value='${accountNumber}' style='border:none' class='w-100' readonly/>
                            </td>
                            <td>
                                <input type='text' name='Details[${currentIndex}].AccountTitle' value='${accountNumberText}' style='border:none' class='w-100' readonly/>
                            </td>
                            <td>
                                <input name='Details[${currentIndex}].Debit' value='${formattedDebit}' style='border:none' class='w-100 money editable-amount' oninput='updateTotalDebitAndCredit()'/>
                            </td>
                            <td>
                                <input name='Details[${currentIndex}].Credit' value='${formattedCredit}' style='border:none' class='w-100 money editable-amount' oninput='updateTotalDebitAndCredit()'/>
                            </td>
                            <td>
                                <input value='${subAccountCodeName}' style='border:none' class='w-100' readonly/>
                                <input name='Details[${currentIndex}].SubAccountId' type='hidden' value='${subAccountId}'/>
                                <input name='Details[${currentIndex}].SubAccountCodeName' type='hidden' value='${subAccountCodeName}'/>
                            </td>
                            <td>
                                <button type='button' class='btn btn-danger btn-sm' onclick='removeRow(this)'>Remove</button>
                            </td>
                         </tr>`;

            $("#accountingEntriesBody").append(newRow);
            $("#AddAccEntry").modal("hide");

            // Reset modal
            $("#AccountNo").val("").trigger("change");
            $("#debit").val("0.0000");
            $("#credit").val("0.0000");
            if ($("#selectionGroup").length !== 0) {
                $("#selectionGroup").remove();
            }

            updateTotalDebitAndCredit();
        }

        function safeVal(selector) {
            var element = $(selector);
            return element.length ? (element.val() || "") : "";
        }

        function safeText(selector) {
            var element = $(selector);
            return element.length ? (element.text() || "") : "";
        }

        function updateTotalDebitAndCredit() {
            var totalDebit = 0;
            var totalCredit = 0;

            $("#accountingEntriesBody tr").each(function () {
                var debitInput = $(this).find("td:eq(2) input").val();
                var creditInput = $(this).find("td:eq(3) input").val();
                debitInput = debitInput ? String(debitInput) : "";
                creditInput = creditInput ? String(creditInput) : "";

                totalDebit += parseNumber(debitInput);
                totalCredit += parseNumber(creditInput);
            });

            $(".totalDebit").text(formatNumber(totalDebit));
            $(".totalCredit").text(formatNumber(totalCredit));
            $("#debit").val("0.0000");
            $("#credit").val("0.0000");

            validateDebitAndCredit();
        }

        function removeRow(button) {
            $(button).closest("tr").remove();
            reindexRows();
            updateTotalDebitAndCredit();
        }

        function reindexRows() {
            $("#accountingEntriesBody tr").each(function (index) {
                $(this).attr('data-index', index);
                $(this).find('input[name^="Details"]').each(function () {
                    var name = $(this).attr('name');
                    var fieldName = name.substring(name.indexOf('].') + 2);
                    $(this).attr('name', 'Details[' + index + '].' + fieldName);
                });
            });
        }
    </script>

    <script>
        function validateDebitAndCredit(event) {
            var totalDebit = parseNumber($(".totalDebit").text());
            var totalCredit = parseNumber($(".totalCredit").text());
            var errorMessage = "";
            var isValid = true;

            if ($("#balance-error-message").length === 0) {
                $("#accountingEntriesBody").after('<div id="balance-error-message" class="text-danger mt-2"></div>');
            }

            if (totalDebit !== totalCredit) {
                errorMessage = "Debit and Credit totals must be equal.";
                isValid = false;
            } else if (totalDebit === 0 || totalCredit === 0) {
                errorMessage = "Debit and Credit cannot be zero.";
                isValid = false;
            }

            $("#balance-error-message").text(errorMessage);
            $("button[type='submit']").prop("disabled", !isValid);

            if (!isValid && event) {
                event.preventDefault();
            }

            return isValid;
        }
    </script>

    <script>
        // Close modal cleanup
        $(document).on("click", "#modalClose, #AddAccEntry .btn-close", function () {
            $("#AccountNo").val("").trigger("change");
            $("#debit").val("0.0000");
            $("#credit").val("0.0000");
            if ($("#selectionGroup").length !== 0) {
                $("#selectionGroup").remove();
            }
        });

        // Format number on blur
        $(document).on("blur", ".editable-amount", function () {
            var value = parseNumber($(this).val());
            $(this).val(formatNumber(value));
            updateTotalDebitAndCredit();
        });

        $(document).on("input", ".editable-amount", function () {
            updateTotalDebitAndCredit();
        });
    </script>

    <script>
        function cvDetails(cvId) {
            if (!cvId) {
                clearFields();
                return;
            }

            $.ajax({
                url: '@Url.Action("GetCV", "JournalVoucher", new { area = "User" })',
                method: "GET",
                data: {id: cvId},
                success: function (data) {
                    let tableBody = $("#tableBody");
                    tableBody.empty();

                    if (data === null) {
                        clearFields();
                        return;
                    }

                    $("#cvNo").text(data.cvNo);
                    $("#date").text(new Date(data.date).toLocaleDateString('en-US', {
                        month: '2-digit',
                        day: '2-digit',
                        year: 'numeric'
                    }));
                    $("#name").text(data.name);
                    $("#address").text(data.address);
                    $("#tinNo").text(data.tinNo);
                    $("#poNo").text(data.poNo);
                    $("#siNo").text(data.siNo);
                    $("#payee").text(data.payee);
                    $("#amount").text(formatNumber(data.amount));
                    $("#particulars").text(data.particulars);
                    $("#checkNo").text(data.checkNo);
                    $("#totalDebit").text(formatNumber(data.totalDebit));
                    $("#totalCredit").text(formatNumber(data.totalCredit));

                    for (let i = 0; i < data.accountNo.length; i++) {
                        let row = $("<tr></tr>");
                        row.append("<td style='width:60%; padding-left:20px;'>" + data.accountNo[i] + " " + data.accountName[i] + "</td>");
                        row.append("<td class='text-end' style='width:7%;'>" + formatNumber(data.debit[i]) + "</td>");
                        row.append("<td class='text-end' style='width:7%;'>" + formatNumber(data.credit[i]) + "</td>");
                        tableBody.append(row);
                    }
                },
                error: function (xhr, status, error) {
                    console.error('Error fetching CV:', error);
                }
            });
        }

        function clearFields() {
            $("#cvNo").text("");
            $("#date").text("");
            $("#name").text("");
            $("#address").text("");
            $("#tinNo").text("");
            $("#poNo").text("");
            $("#siNo").text("");
            $("#payee").text("");
            $("#amount").text("");
            $("#particulars").text("");
            $("#checkNo").text("");
            $("#totalDebit").text("");
            $("#totalCredit").text("");
            $("#tableBody").empty();
        }

        function populateSelectOptions(selector, items, selectedValue) {
            const select = $(selector);
            select.empty().append('<option></option>');

            $.each(items, function (_, item) {
                const option = new Option(item.text, item.value, false, item.value == selectedValue);
                select.append(option);
            });

            select.trigger('change.select2');
        }

        function loadEmployeeOptions(employeeId, selectedCvId, selectedPrNo) {
            if (!employeeId) {
                populateSelectOptions("#CVId", [], null);
                populateSelectOptions("#PRNo", [], null);
                clearFields();
                return;
            }

            $.get('@Url.Action("GetLiquidationCheckVouchersByEmployee", "JournalVoucher", new { area = "User" })',
                {employeeId: employeeId, selectedCvId: selectedCvId})
                .done(function (data) {
                    populateSelectOptions("#CVId", data, selectedCvId);
                    cvDetails($("#CVId").val());
                });

            $.get('@Url.Action("GetProvisionalReceiptsByEmployee", "JournalVoucher", new { area = "User" })',
                {employeeId: employeeId, selectedPrNo: selectedPrNo})
                .done(function (data) {
                    populateSelectOptions("#PRNo", data, selectedPrNo);
                });
        }

        $("#EmployeeId").change(function () {
            loadEmployeeOptions($(this).val(), null, null);
        });

        $(".checkVoucher").each(function () {
            cvDetails($(this).val());
        });

        $(".checkVoucher").change(function () {
            var cvId = $(this).val();
            cvDetails(cvId);
        });

        loadEmployeeOptions($("#EmployeeId").val(), $("#CVId").val(), $("#PRNo").val());
    </script>
}
