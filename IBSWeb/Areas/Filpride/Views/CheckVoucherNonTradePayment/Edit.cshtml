@model CheckVoucherNonTradePaymentViewModel

@{
    ViewData["Title"] = "Check Voucher Non-Trade Payment - Edit";
}

<link rel="stylesheet" href="~/css/form-style.css">

<div class="loader-container">
    <div class="loader"></div>
    <div class="loader-text">Loading...</div>
</div>
<div class="card shadow border-0 mt-4">
    <div class="card-header bg-secondary bg-gradient ml-0 py-3">
        <div class="row">
            <div class="col-12 text-center">
                <h2 class="text-white py-2">@ViewData["Title"]</h2>
            </div>
        </div>
    </div>
    <div class="card-body p-4">
        <form method="post" enctype="multipart/form-data">
            @Html.AntiForgeryToken()
            <div class="row">
                <div asp-validation-summary="ModelOnly" class="text-danger"></div>
                <input asp-for="CvId" type="hidden"/>
                <div class="form-group mb-3">
                    <label asp-for="TransactionDate" class="control-label"></label><span class="required">*</span>
                    <input asp-for="TransactionDate" 
                           type="Date" 
                           class="form-control" 
                           min="@Model.MinDate.ToString("yyyy-MM-dd")"/>
                    <span asp-validation-for="TransactionDate" class="text-danger"></span>
                </div>
                <div class="form-group mb-3">
                    <label class="control-label">Supplier<span class="required">*</span></label>
                    <select asp-for="MultipleSupplierId" asp-items="@Model.Suppliers" class="form-select js-select2 GetCVList" style="width: 100%" required>
                        <option></option>
                    </select>
                    <span asp-validation-for="MultipleSupplierId" class="text-danger"></span>
                </div>
                <div class="form-group mb-3">
                    <label asp-for="MultipleCvId" class="control-label">CV #</label><span class="required">*</span>
                    <select asp-for="MultipleCvId" asp-items="@Model.CheckVouchers" class="form-select js-multiple multipleCvId" multiple="multiple" style="width:100%" required>
                        <option></option>
                    </select>
                    <span asp-validation-for="MultipleCvId" class="text-danger"></span>
                </div>
                <div class="form-floating mb-3">
                    <input asp-for="OldCVNo" type="text" class="form-control" placeholder="Old CV No." required/>
                    <label asp-for="OldCVNo" class="control-label ms-2">Old CV #<span class="required">*</span></label>
                    <span asp-validation-for="OldCVNo" class="text-danger"></span>
                </div>
                <table class="table">
                    <thead>
                    <tr>
                        <th class="text-center">CV List</th>
                        <th class="text-center">Amount to Pay</th>
                    </tr>
                    </thead>
                    <tbody class="cvAmountList">
                    </tbody>
                </table>
                <div class="form-floating mb-3">
                    <input asp-for="Payee" type="text" class="form-control" placeholder="Optional" readonly/>
                    <label asp-for="Payee" class="control-label ms-2"></label>
                    <span asp-validation-for="Payee" class="text-danger"></span>
                </div>
                <div class="form-floating mb-3">
                    <input asp-for="PayeeAddress" type="text" class="form-control" placeholder="Optional" readonly/>
                    <label asp-for="PayeeAddress" class="control-label ms-2"></label>
                    <span asp-validation-for="PayeeAddress" class="text-danger"></span>
                </div>
                <div class="form-floating mb-3">
                    <input asp-for="PayeeTin" type="text" class="form-control" placeholder="Optional" readonly/>
                    <label asp-for="PayeeTin" class="control-label ms-2"></label>
                    <span asp-validation-for="PayeeTin" class="text-danger"></span>
                </div>
                <div class="form-group mb-3">
                    <label asp-for="Total" class="control-label"></label><span class="required">*</span>
                    <input asp-for="Total" class="form-control money totalAmount total" value="" placeholder="0.000" readonly/>
                    <span asp-validation-for="Total" class="text-danger"></span>
                </div>
                <div class="form-group mb-3">
                    <label class="control-label">Bank Account<span class="required">*</span></label>
                    <select asp-for="BankId" asp-items="@Model.Banks" class="form-select js-select2" style="width: 100%" required>
                        <option></option>
                    </select>
                    <span asp-validation-for="BankId" class="text-danger"></span>
                </div>
                <div class="form-floating mb-3">
                    <input asp-for="CheckNo" type="text" class="form-control" placeholder="Input check #"/>
                    <label asp-for="CheckNo" class="control-label ms-2">Check No.<span class="required">*</span></label>
                    <span asp-validation-for="CheckNo" class="text-danger"></span>
                </div>
                <div class="form-group mb-3">
                    <label asp-for="CheckDate" class="control-label"></label><span class="required">*</span>
                    <input asp-for="CheckDate" type="Date" class="form-control"/>
                    <span asp-validation-for="CheckDate" class="text-danger"></span>
                </div>
                <div class="form-group mb-3">
                    <label class="control-label">Upload File (Optional)</label>
                    <input name="file" type="file" class="form-control"/>
                </div>
                <div class="form-floating mb-3">
                    <textarea asp-for="Particulars" class="form-control" placeholder="Leave a remarks here" style="height: 100px"></textarea>
                    <label asp-for="Particulars" class="control-label ms-2">Particulars<span class="required">*</span></label>
                    <span asp-validation-for="Particulars" class="text-danger"></span>
                </div>
                <div class="form-group table-responsive">
                    <table class="table" style="min-width: 800px">
                        <thead>
                        <tr>
                            <th>Account No.</th>
                            <th>Account Title</th>
                            <th>Debit</th>
                            <th>Credit</th>
                        </tr>
                        </thead>
                        <tbody id="accountingEntriesBody">
                        </tbody>
                        <tfoot>
                        <tr>
                            <td class="text-end" colspan="2">TOTAL:</td>
                            <td class="totalDebit">0.0000</td>
                            <td class="totalCredit">0.0000</td>
                        </tr>
                        </tfoot>
                    </table>
                </div>
                <br/>
                <div class="row pt-2">
                    <div class="col-6 col-md-3">
                        <button type="submit" class="btn btn-primary form-control">Save</button>
                    </div>
                    <div class="col-6 col-md-3">
                        <a asp-area="Filpride" asp-controller="CheckVoucherNonTradePayment" asp-action="Index" class="btn btn-outline-primary border  form-control ">Back to List</a>
                    </div>
                </div>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
    <script>
        $("#MultipleSupplierId").change(function () {
            let supplierId = $(this).val();
            getSupplierDetails(supplierId)
        });

        function getSupplierDetails(supplierId) {
            if (supplierId !== "") {
                $.ajax({
                    url: '@Url.Action("GetSupplierDetails", "CheckVoucherNonTradePayment", new { area = "Filpride" })',
                    method: "GET",
                    data: { supplierId: supplierId },
                    success: function (data) {
                        if (data) {
                            $("#Payee").val(data.name);
                            $("#PayeeAddress").val(data.address);
                            $("#PayeeTin").val(data.tinNo);
                        }
                    },
                    error: function (xhr, status, error) {
                        console.error("Error occurred:", status, error);
                    }
                });
            } else {
                $("#Payee").val("");
                $("#PayeeAddress").val("");
                $("#PayeeTin").val("");
            }
        }

        $(function () {
            $(".GetCVList").change(function () {
                var suppId = $(this).val();
                let paymentId = $("#CvId").val();
                
                if (suppId !== "") {
                    $.ajax({
                        url: "@Url.Action("GetCVs", "CheckVoucherNonTradePayment")",
                        method: "GET",
                        data: { supplierId: suppId, paymentId: paymentId },
                        success: function (data) {
                            if (data) {
                                $(".multipleCvId").empty();
                                $.each(data, function (index, cv) {
                                    if (cv && cv.cvNumber) {
                                        $('.multipleCvId').append('<option value="' + cv.id + '">' + cv.cvNumber + '</option>');
                                    } else {
                                        console.error("Invalid CV object:", cv);
                                    }
                                });
                            } else {
                                $(".multipleCvId").empty();
                            }
                        },
                        error: function (xhr, status, error) {
                            console.error('Error fetching CVs:', error);
                        }
                    });
                } else {
                    $(".multipleCvId").empty();
                }
            });
        });

        $(document).ready(function () {
            $("#MultipleCvId").change(function () {
                let cvSelect = $("#MultipleCvId").val();
                let supplierId = $(".GetCVList").val();
                let paymentId = $("#CvId").val();

                $("#accountingEntriesBody").empty();
                $(".cvAmountList").empty();

                if (cvSelect && cvSelect.length > 0) {
                    $.ajax({
                        url: '@Url.Action("GetMultipleInvoiceDetails", "CheckVoucherNonTradePayment", new { area = "Filpride" })',
                        method: "GET",
                        traditional: true,
                        data: { 
                            cvId: cvSelect, 
                            supplierId: supplierId,
                            paymentId: paymentId
                        },
                        success: function (data) {
                            if (data && data.journalEntries) {

                                // Add CV balance rows with editable inputs
                                if (data.cvBalances && data.cvBalances.length > 0) {
                                    data.cvBalances.forEach(function(cv, index) {
                                        var cvRow = `<tr>
                                                        <td class="text-center">${cv.cvNumber}</td>
                                                        <td class="text-center">
                                                            <input type="number" 
                                                                   class="form-control amount-input" 
                                                                   name="PaymentDetails[${index}].AmountPaid"
                                                                   data-max-balance="${cv.maxBalance}"
                                                                   data-index="${index}"
                                                                   value="${(cv.balance).toFixed(4)}"
                                                                   min="0.0001" 
                                                                   max="${cv.maxBalance}" 
                                                                   step="0.0001"
                                                                   required />
                                                            <small class="text-muted d-block">Max: ${formatNumberToFour(cv.maxBalance)}</small>
                                                            <span class="text-danger amount-error-${index}" style="display:none;"></span>
                                                        </td>
                                                        <input type="hidden" name="PaymentDetails[${index}].CVId" value="${cv.cvId}" />
                                                    </tr>`;
                                        $(".cvAmountList").append(cvRow);
                                    });
                                    
                                    // Store original data for recalculation
                                    window.originalTotal = data.totalCredit;
                                    window.originalEntries = data.journalEntries;
                                    
                                    // Add validation and recalculation on amount change
                                    $(".amount-input").on("input", function() {
                                        var input = $(this);
                                        var max = parseFloat(input.data("max-balance"));
                                        var val = parseFloat(input.val()) || 0;
                                        var idx = input.data("index");
                                        var err = $(`.amount-error-${idx}`);
                                        
                                        err.hide();
                                        input.removeClass("is-invalid");
                                        
                                        if (val <= 0 || val > max) {
                                            err.text(val <= 0 ? "Must not be 0 or negative" : "Exceeds balance").show();
                                            input.addClass("is-invalid");
                                        }
                                        
                                        recalculateTotals();
                                        validateDebitAndCredit();
                                    });
                                }

                                // Add journal entries
                                data.journalEntries.forEach(function (entry) {
                                    var newRow = `<tr>
                                            <td><input type="text" name="AccountNumber" value="${entry.accountNumber}" class="w-100" style='border:none' readonly /></td>
                                            <td><input name='AccountTitle' value='${entry.accountTitle}' class="w-100" style='border:none' readonly /></td>
                                            <td><input name="Debit" value='${formatNumberToFour(entry.debit)}' class="w-100 debit" style='border:none' readonly /></td>
                                            <td><input name="Credit" value='${formatNumberToFour(entry.credit)}' class="w-100 credit" style='border:none' readonly /></td>
                                        </tr>`;
                                    $("#accountingEntriesBody").append(newRow);
                                });

                                $(".totalDebit").text(formatNumberToFour(data.totalDebit));
                                $(".totalCredit").text(formatNumberToFour(data.totalCredit));
                                $("#Total").val(formatNumberToFour(data.totalCredit));

                                const minDateFromModel = "@Model.MinDate.ToString("yyyy-MM-dd")";
                                if(data.transactionDate > minDateFromModel){
                                    $("#TransactionDate").val(data.transactionDate).attr("min", data.transactionDate)
                                }
                                
                                validateDebitAndCredit();
                            }
                        },
                        error: function (xhr, status, error) {
                            console.error("Error fetching journal entries:", error);
                        }
                    });
                } else {
                    $(".totalDebit").text("0.0000");
                    $(".totalCredit").text("0.0000");
                }
            });
        });

        $(document).ready(function () {
            $("#MultipleCvId").trigger("change");
        });
        
        // Recalculate totals and journal entries based on changed amounts
        function recalculateTotals() {
            if (!window.originalEntries || !window.originalTotal) return;
            
            var newTotal = 0;
            var hasInvalid = false;
            $(".amount-input").each(function() {
                var val = parseFloat($(this).val()) || 0;
                var max = parseFloat($(this).data("max-balance"));
                if (val <= 0 || val > max) {
                    hasInvalid = true;
                }
                newTotal += val;
            });
            
            if (hasInvalid || newTotal === 0 || window.originalTotal === 0) return;

            var ratio = newTotal / window.originalTotal;
            
            $("#accountingEntriesBody").empty();
            var newDebitTotal = 0;
            var newCreditTotal = 0;
            
            window.originalEntries.forEach(function(entry) {
                var newDebit = entry.debit * ratio;
                var newCredit = entry.credit * ratio;
                newDebitTotal += newDebit;
                newCreditTotal += newCredit;
                
                var row = `<tr>
                    <td><input type="text" name="AccountNumber" value="${entry.accountNumber}" class="w-100" style='border:none' readonly /></td>
                    <td><input name='AccountTitle' value='${entry.accountTitle}' class="w-100" style='border:none' readonly /></td>
                    <td><input name="Debit" value='${formatNumberToFour(newDebit)}' class="w-100 debit" style='border:none' readonly /></td>
                    <td><input name="Credit" value='${formatNumberToFour(newCredit)}' class="w-100 credit" style='border:none' readonly /></td>
                </tr>`;
                $("#accountingEntriesBody").append(row);
            });
            
            $(".totalDebit").text(formatNumberToFour(newDebitTotal));
            $(".totalCredit").text(formatNumberToFour(newCreditTotal));
            $("#Total").val(formatNumberToFour(newCreditTotal));
        }
        
    </script>
    <script>
        function validateDebitAndCredit() {
            var totalDebit = parseNumber($(".totalDebit").text());
            var totalCredit = parseNumber($(".totalCredit").text());
            var errorMessage = "";
            var isValid = true;

            if ($("#balance-error-message").length === 0) {
                $("#accountingEntriesBody").after('<div id="balance-error-message" class="text-danger mt-2"></div>');
            }

            // Check if any amount inputs are invalid
            if ($(".amount-input.is-invalid").length > 0) {
                errorMessage = "Please fix invalid payment amounts.";
                isValid = false;
            } else if (totalDebit !== totalCredit) {
                errorMessage = "Debit and Credit totals must be equal.";
                isValid = false;
            } else if (totalDebit === 0 && totalCredit === 0) {
                errorMessage = "Debit and Credit cannot both be zero.";
                isValid = false;
            } else if (totalDebit === 0 || totalCredit === 0) {
                errorMessage = "Debit and Credit cannot be zero.";
                isValid = false;
            }

            $("#balance-error-message").text(errorMessage);
            $("button[type='submit']").prop("disabled", !isValid);

            return isValid;
        }

        $('input[name="CheckNo"]').on('blur', function() {
            var checkNo = $(this).val();
            var cvId = $('input[name="CvId"]').val();
            if (checkNo) {
                $.ajax({
                    url: '@Url.Action("CheckNoIsExist", "CheckVoucherNonTradePayment", new { area = "Filpride" })',
                    type: "GET",
                    data: { checkNo: checkNo, cvId: cvId },
                    success: function(exists) {
                        const submitButton = $('button[type="submit"]');

                        if (exists) {
                            alert("Check # already exists. Please enter a different number.");
                            $('input[name="CheckNo"]').addClass('is-invalid');

                            if ($('input[name="CheckNo"]').next('.text-danger.check-no-exists').length === 0) {
                                $('input[name="CheckNo"]').after('<span class="text-danger check-no-exists">Check # already exists</span>');
                            }

                            submitButton.prop('disabled', true);
                        } else {
                            $('input[name="CheckNo"]').removeClass('is-invalid');
                            $('.check-no-exists').remove();
                            submitButton.prop('disabled', false);
                        }
                    },
                    error: function(xhr, status, error) {
                        console.log("Error checking CheckNo: " + error);
                    }
                });
            }
        });
        
    </script>
}