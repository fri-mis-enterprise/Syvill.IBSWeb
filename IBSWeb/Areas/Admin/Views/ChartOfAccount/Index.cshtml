@model List<ChartOfAccount>

@{
    ViewData["Title"] = "Chart of Account";
    var showHidden = ViewBag.ShowHidden is bool showHiddenValue && showHiddenValue;
}

<link rel="stylesheet" href="~/css/index-style.css">

<div class="card shadow border-0 mt-4">
    @Html.AntiForgeryToken()
    <div class="card-header bg-secondary bg-gradient ml-0 py-3">
        <div class="row">
            <div class="col-12 text-center">
                <h2 class="text-white py-2">@ViewData["Title"]</h2>
            </div>
        </div>
    </div>
    <div class="card-body p-4 table-responsive">
        <div class="row pb-3">
            <div class="col-6">
            </div>
            <div class="col-6 text-end">
                <a class="btn btn-outline-secondary me-2"
                   href="@Url.Action("Index", "ChartOfAccount", new { area = "Admin", showHidden = !showHidden })">
                    @(showHidden ? "Hide hidden accounts" : "Show hidden accounts")
                </a>
                <a class="btn btn-primary" id="closeAllAccordions">Fold all levels</a>
            </div>
        </div>

        <div class="accordion" id="accordionExample1">
            @foreach (var l1 in Model)
            {
                <div class="row">
                    <div class="accordion-item col-11 p-0">
                        <h2 class="accordion-header">
                            <button class="accordion-button collapsed" type="button"
                                    data-bs-toggle="collapse"
                                    data-bs-target="#accordion-@Html.DisplayFor(model => l1.AccountNumber)"
                                    aria-expanded="false"
                                    aria-controls="accordion-@Html.DisplayFor(model => l1.AccountNumber)">
                                L1: @Html.DisplayFor(obj => l1.AccountName) - @Html.DisplayFor(obj => l1.AccountNumber)
                                @if (l1.IsHidden)
                                {
                                    <span class="badge bg-secondary ms-2">Hidden</span>
                                }
                            </button>
                        </h2>
                        <div id="accordion-@Html.DisplayFor(model => l1.AccountNumber)"
                             class="accordion-collapse collapse"
                             data-bs-parent="#accordionExample1">
                            <div class="accordion-body">
                                <button class="btn btn-outline-secondary mb-3 toggleHiddenAccount"
                                        data-account-id="@l1.AccountId"
                                        data-is-hidden="@l1.IsHidden.ToString().ToLowerInvariant()">
                                    @(l1.IsHidden ? "Unhide Account" : "Hide Account")
                                </button>

                                <div class="accordion" id="LGroup-@l1.AccountNumber">
                                    @foreach (var l2 in l1.Children.OrderBy(coa => coa.AccountNumber))
                                    {
                                        <div class="row">
                                            <div class="accordion-item col-11 p-0">
                                                <h2 class="accordion-header">
                                                    <button class="accordion-button collapsed" type="button"
                                                            data-bs-toggle="collapse"
                                                            data-bs-target="#accordion-@Html.DisplayFor(model => l2.AccountNumber)"
                                                            aria-expanded="false"
                                                            aria-controls="accordion-@Html.DisplayFor(model => l2.AccountNumber)">
                                                        L2: @Html.DisplayFor(obj => l2.AccountName) - @Html.DisplayFor(obj => l2.AccountNumber)
                                                        @if (l2.IsHidden)
                                                        {
                                                            <span class="badge bg-secondary ms-2">Hidden</span>
                                                        }
                                                    </button>
                                                </h2>
                                                <div id="accordion-@Html.DisplayFor(model => l2.AccountNumber)"
                                                     class="accordion-collapse collapse"
                                                     data-bs-parent="#LGroup-@l1.AccountNumber">
                                                    <div class="accordion-body">
                                                        <button class="btn btn-outline-secondary mb-3 toggleHiddenAccount"
                                                                data-account-id="@l2.AccountId"
                                                                data-is-hidden="@l2.IsHidden.ToString().ToLowerInvariant()">
                                                            @(l2.IsHidden ? "Unhide Account" : "Hide Account")
                                                        </button>

                                                        <div class="accordion" id="LGroup-@l2.AccountNumber">
                                                            @foreach (var l3 in l2.Children.OrderBy(coa => coa.AccountNumber))
                                                            {
                                                                <div class="row">
                                                                    <div class="accordion-item col-11 p-0">
                                                                        <h2 class="accordion-header">
                                                                            <button class="accordion-button collapsed" type="button"
                                                                                    data-bs-toggle="collapse"
                                                                                    data-bs-target="#accordion-@Html.DisplayFor(model => l3.AccountNumber)"
                                                                                    aria-expanded="false"
                                                                                    aria-controls="accordion-@Html.DisplayFor(model => l3.AccountNumber)">
                                                                                L3: @Html.DisplayFor(obj => l3.AccountName) - @Html.DisplayFor(obj => l3.AccountNumber)
                                                                                @if (l3.IsHidden)
                                                                                {
                                                                                    <span class="badge bg-secondary ms-2">Hidden</span>
                                                                                }
                                                                            </button>
                                                                        </h2>
                                                                        <div id="accordion-@Html.DisplayFor(model => l3.AccountNumber)"
                                                                             class="accordion-collapse collapse"
                                                                             data-bs-parent="#LGroup-@l2.AccountNumber">
                                                                            <div class="accordion-body">
                                                                                <button class="btn btn-outline-secondary mb-3 me-2 toggleHiddenAccount"
                                                                                        data-account-id="@l3.AccountId"
                                                                                        data-is-hidden="@l3.IsHidden.ToString().ToLowerInvariant()">
                                                                                    @(l3.IsHidden ? "Unhide Account" : "Hide Account")
                                                                                </button>

                                                                                <button class="btn btn-primary mb-3 createAccount" data-account-id="@l3.AccountId">Create Level 4 Account</button>

                                                                                <div class="accordion" id="LGroup-@l3.AccountNumber">
                                                                                    @foreach (var l4 in l3.Children.OrderBy(coa => coa.AccountNumber))
                                                                                    {
                                                                                        <div class="row">
                                                                                            <div class="accordion-item col-10 p-0">
                                                                                                <h2 class="accordion-header">
                                                                                                    <button class="accordion-button collapsed" type="button"
                                                                                                            data-bs-toggle="collapse"
                                                                                                            data-bs-target="#accordion-@Html.DisplayFor(model => l4.AccountNumber)"
                                                                                                            aria-expanded="false"
                                                                                                            aria-controls="accordion-@Html.DisplayFor(model => l4.AccountNumber)">
                                                                                                        L4: @Html.DisplayFor(obj => l4.AccountName) - @Html.DisplayFor(obj => l4.AccountNumber)
                                                                                                        @if (l4.IsHidden)
                                                                                                        {
                                                                                                            <span class="badge bg-secondary ms-2">Hidden</span>
                                                                                                        }
                                                                                                    </button>
                                                                                                </h2>
                                                                                                <div id="accordion-@Html.DisplayFor(model => l4.AccountNumber)"
                                                                                                     class="accordion-collapse collapse"
                                                                                                     data-bs-parent="#LGroup-@l3.AccountNumber">
                                                                                                    <div class="accordion-body">
                                                                                                        <button class="btn btn-outline-secondary mb-3 me-2 toggleHiddenAccount"
                                                                                                                data-account-id="@l4.AccountId"
                                                                                                                data-is-hidden="@l4.IsHidden.ToString().ToLowerInvariant()">
                                                                                                            @(l4.IsHidden ? "Unhide Account" : "Hide Account")
                                                                                                        </button>

                                                                                                        <button class="btn btn-primary mb-3 createAccount" data-account-id="@l4.AccountId">Create Level 5 Account</button>

                                                                                                        <div class="accordion" id="LGroup-@l4.AccountNumber">
                                                                                                            @foreach (var l5 in l4.Children.OrderBy(coa => coa.AccountNumber))
                                                                                                            {
                                                                                                                <div class="row">
                                                                                                                    <div class="accordion-item col-10 p-0">
                                                                                                                        <h2 class="accordion-header">
                                                                                                                            <button class="accordion-button collapsed" type="button"
                                                                                                                                    data-bs-toggle="collapse"
                                                                                                                                    data-bs-target="#accordion-@Html.DisplayFor(model => l5.AccountNumber)"
                                                                                                                                    aria-expanded="false"
                                                                                                                                    aria-controls="accordion-@Html.DisplayFor(model => l5.AccountNumber)">
                                                                                                                                L5: @Html.DisplayFor(obj => l5.AccountName) - @Html.DisplayFor(obj => l5.AccountNumber)
                                                                                                                                @if (l5.IsHidden)
                                                                                                                                {
                                                                                                                                    <span class="badge bg-secondary ms-2">Hidden</span>
                                                                                                                                }
                                                                                                                            </button>
                                                                                                                        </h2>
                                                                                                                        <div id="accordion-@Html.DisplayFor(model => l5.AccountNumber)"
                                                                                                                             class="accordion-collapse collapse"
                                                                                                                             data-bs-parent="#LGroup-@l4.AccountNumber">
                                                                                                                            <div class="accordion-body">
                                                                                                                                <button class="btn btn-outline-secondary mb-3 toggleHiddenAccount"
                                                                                                                                        data-account-id="@l5.AccountId"
                                                                                                                                        data-is-hidden="@l5.IsHidden.ToString().ToLowerInvariant()">
                                                                                                                                    @(l5.IsHidden ? "Unhide Account" : "Hide Account")
                                                                                                                                </button>
                                                                                                                                <div>No Children!</div>
                                                                                                                            </div>
                                                                                                                        </div>
                                                                                                                    </div>
                                                                                                                    <div class="col-2 align-top align-text-top pt-2">
                                                                                                                        <button class="btn btn-light mb-3 editAccount col-12" data-account-id="@l5.AccountId" data-account-name="@l5.AccountName">Edit</button>
                                                                                                                    </div>
                                                                                                                </div>
                                                                                                            }
                                                                                                        </div>

                                                                                                    </div>
                                                                                                </div>
                                                                                            </div>
                                                                                            <div class="col-2 align-top align-text-top text-center pt-2">
                                                                                                <button class="btn btn-light mb-3 editAccount col-12" data-account-id="@l4.AccountId" data-account-name="@l4.AccountName">Edit</button>
                                                                                            </div>
                                                                                        </div>
                                                                                    }
                                                                                </div>

                                                                            </div>
                                                                        </div>
                                                                    </div>
                                                                </div>
                                                            }
                                                        </div>

                                                    </div>
                                                </div>
                                            </div>
                                        </div>
                                    }
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

            }
        </div>

    </div>
</div>

@section Scripts
{
    <script>
        document.addEventListener('DOMContentLoaded', function() {

            document.getElementById('closeAllAccordions').addEventListener('click', function() {

                document.querySelectorAll('.accordion-collapse.show').forEach(accordion => {

                    accordion.classList.remove('show');

                    let button = accordion.closest('.accordion-item').querySelector('.accordion-button');
                    if (button) {
                        button.setAttribute('aria-expanded', 'false');
                        button.classList.remove('active');
                    }
                });
            });
        });


        $(document).ready(function() {
            const requestVerificationToken = $('input[name="__RequestVerificationToken"]').val();
            const showHidden = '@showHidden'.toLowerCase() === 'true';

            $('.createAccount').on('click', function(e) {
                e.preventDefault();
                let parentId = $(this).data('account-id');

                Swal.fire({
                    title: 'Enter Account Name',
                    input: 'text',
                    inputAttributes: {
                        autocapitalize: 'off'
                    },
                    showCancelButton: true,
                    confirmButtonText: 'Create',
                    showLoaderOnConfirm: true,
                    preConfirm: (accountName) => {
                        // Validation if needed
                        if (!accountName || accountName.trim() === '') {
                            Swal.showValidationMessage('Account name is required');
                        }
                        return accountName;
                    }
                }).then((result) => {
                    if (result.isConfirmed) {
                        let accountName = result.value;
                        console.log(accountName);

                        $.ajax({
                            url: '@Url.Action("Create", "ChartOfAccount", new { area = "Admin" })',
                            type: "GET",
                            data: { parentId: parentId, accountName: accountName },
                            success: function (response) {
                                if (response.redirectUrl) {
                                    window.location.href = response.redirectUrl;
                                } else {
                                    console.log("Operation was successful but no redirect.");
                                }
                            },
                            error: function (xhr, status, error) {
                                console.error("AJAX error:", error);
                            }
                        });
                    }
                });
            });


            $('.editAccount').on('click', function(e) {
                e.preventDefault();
                let accountId = $(this).data('account-id');
                let accountName = $(this).data('account-name');

                Swal.fire({
                    title: 'Edit Account Name',
                    input: 'text',
                    inputValue: accountName,
                    inputAttributes: {
                        autocapitalize: 'off'
                    },
                    showCancelButton: true,
                    confirmButtonText: 'Save',
                    showLoaderOnConfirm: true,
                    preConfirm: (accountName) => {
                        if (!accountName || accountName.trim() === '') {
                            Swal.showValidationMessage('Account name cannot be blank');
                        }
                        return accountName;
                    }
                }).then((result) => {
                    if (result.isConfirmed) {
                        let accountName = result.value;
                        console.log(accountName);

                        $.ajax({
                            url: '@Url.Action("Edit", "ChartOfAccount", new { area = "Admin" })',
                            type: "GET",
                            data: { accountId: accountId, accountName: accountName },
                            success: function (response) {
                                if (response.redirectUrl) {
                                    // If the response includes a redirect URL, redirect the browser
                                    window.location.href = response.redirectUrl;
                                } else {
                                    // Handle other success scenarios if needed
                                    console.log("Operation was successful but no redirect.");
                                }
                            },
                            error: function (xhr, status, error) {
                                console.error("AJAX error:", error);
                            }
                        });
                    }
                });
            });

            $('.toggleHiddenAccount').on('click', function(e) {
                e.preventDefault();
                let accountId = $(this).data('account-id');
                let isHidden = $(this).data('is-hidden') === true || $(this).data('is-hidden') === 'true';

                Swal.fire({
                    title: isHidden ? 'Unhide account?' : 'Hide account?',
                    text: isHidden
                        ? 'This account will appear again in the default Chart of Account view.'
                        : 'This account will be removed from the default Chart of Account view.',
                    icon: 'question',
                    showCancelButton: true,
                    confirmButtonText: isHidden ? 'Unhide' : 'Hide'
                }).then((result) => {
                    if (!result.isConfirmed) {
                        return;
                    }

                    $.ajax({
                        url: '@Url.Action("ToggleHidden", "ChartOfAccount", new { area = "Admin" })',
                        type: 'POST',
                        data: {
                            __RequestVerificationToken: requestVerificationToken,
                            accountId: accountId,
                            showHidden: showHidden
                        },
                        success: function(response) {
                            if (response.redirectUrl) {
                                window.location.href = response.redirectUrl;
                            }
                        },
                        error: function(xhr, status, error) {
                            console.error('AJAX error:', error);
                        }
                    });
                });
            });
        });

    </script>

}
