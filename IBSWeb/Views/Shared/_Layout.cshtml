<script>
    $(document).ready(function () {
        // Check if the user is logged in
        if ($('#hfUsername').length && $('#hfUsername').val() !== "") {
            // Function to fetch and update notification count
            function updateNotificationCount() {
                $.ajax({
                    url: '@Url.Action("GetNotificationCount", "Notification", new { area = "User" })',
                    type: 'GET',
                    success: function (count) {
                        $('#notificationCount').text(count);
                    },
                    error: function () {
                        console.error("Error fetching notification count");
                    }
                });
            }

            // Initial load
            updateNotificationCount();

            // Optional: Poll every 30 seconds to update count
            setInterval(updateNotificationCount, 30000); // 30,000 ms = 30 seconds
        }
    });
</script>
<script>
    const darkModeMediaQuery = window.matchMedia('(prefers-color-scheme: dark)');

    function updateFavicon(e) {
        const faviconLight = document.getElementById('favicon-light');
        const faviconDark = document.getElementById('favicon-dark');

        if (e.matches) {
            faviconDark.rel = 'shortcut icon';
            faviconLight.rel = '';
        } else {
            faviconDark.rel = '';
            faviconLight.rel = 'shortcut icon';
        }
    }

    // Initial check
    updateFavicon(darkModeMediaQuery);

    // Listen for changes
    darkModeMediaQuery.addEventListener('change', updateFavicon);
</script>
